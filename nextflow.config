process {
    executor = 'local'

    // sensible defaults (safe for laptop / modest system)
    cpus   = 2
    memory = '4 GB'
    time   = '2h'

    // -------- RESOURCE GROUPS VIA LABELS --------

    withLabel: low {
        cpus   = 1
        memory = '1 GB'
    }

    withLabel: medium {
        cpus   = 1
        memory = '2 GB'
    }

    withLabel: high {
        cpus   = 3
        memory = '6 GB'
    }

    // -------- CONTAINERS --------

    withName: FASTQC {
        container = 'biocontainers/fastqc:v0.11.9_cv8'
    }

    withName: ALIGN {
        container = 'biocontainers/bwa:v0.7.17_cv1'
    }

    withName: SAMTOOLS_VIEW {
        container = 'quay.io/biocontainers/samtools:1.17--h00cdaf9_0'
    }

    withName: SORT_BAM {
        container = 'quay.io/biocontainers/samtools:1.17--h00cdaf9_0'
    }

    withName: INDEX_BAM {
        container = 'quay.io/biocontainers/samtools:1.17--h00cdaf9_0'
    }

    withName: FLAGSTAT {
        container = 'quay.io/biocontainers/samtools:1.17--h00cdaf9_0'
    }

    withName: MULTIQC {
        container = 'quay.io/biocontainers/multiqc:1.21--pyhdfd78af_0'
    }
}

docker {
    enabled = true

    // ensures files are owned by you, not root
    runOptions = '-u $(id -u):$(id -g)'
}

executor {
    // prevents too many jobs running at once
    queueSize = 4
}

profiles {

    // default local
    standard {
        process.executor = 'local'
    }

    // explicit docker
    docker {
        docker.enabled = true
    }

    // HPC scheduler (example: SLURM)
    slurm {
        process.executor = 'slurm'
    }

    // HPC containers (no Docker)
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
    }
}
